<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.tlcsdm.fxtemplate.controller.MainController"
            prefWidth="900" prefHeight="700">

    <top>
        <VBox>
            <HBox style="-fx-background-color: -color-bg-subtle;">
                <HBox fx:id="titleDragArea"
                      alignment="CENTER_LEFT" spacing="8"
                      HBox.hgrow="ALWAYS"
                      onMousePressed="#onTitleBarMousePressed"
                      onMouseDragged="#onTitleBarMouseDragged"
                      onMouseClicked="#onTitleBarMouseClicked">
                    <padding>
                        <Insets top="6" right="10" bottom="6" left="10"/>
                    </padding>
                    <ImageView fitWidth="20" fitHeight="20" preserveRatio="true">
                        <image>
                            <Image url="@logo.png"/>
                        </image>
                    </ImageView>
                    <Label fx:id="windowTitleLabel" text="%app.title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>
                <Button text="—" onAction="#onMinimizeWindow"
                        onMouseEntered="#onWindowButtonMouseEntered"
                        onMouseExited="#onWindowButtonMouseExited"
                        style="-fx-background-radius: 0; -fx-background-color: transparent; -fx-padding: 6 12 6 12;"
                        accessibleText="%window.minimize"
                        focusTraversable="false"/>
                <Button fx:id="maximizeButton" text="□" onAction="#onToggleMaximizeWindow"
                        onMouseEntered="#onWindowButtonMouseEntered"
                        onMouseExited="#onWindowButtonMouseExited"
                        style="-fx-background-radius: 0; -fx-background-color: transparent; -fx-padding: 6 12 6 12;"
                        accessibleText="%window.maximize"
                        focusTraversable="false"/>
                <Button fx:id="closeButton" text="✕" onAction="#onCloseWindow"
                        onMouseEntered="#onWindowButtonMouseEntered"
                        onMouseExited="#onWindowButtonMouseExited"
                        style="-fx-background-radius: 0; -fx-background-color: transparent; -fx-padding: 6 12 6 12;"
                        accessibleText="%window.close"
                        focusTraversable="false"/>
            </HBox>
            <MenuBar>
                <Menu text="%menu.file">
                    <MenuItem text="%menu.settings" onAction="#openSettings"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="%menu.restart" onAction="#restartApplication"/>
                    <MenuItem text="%menu.exit" onAction="#exitApplication"/>
                </Menu>
                <Menu text="%menu.help">
                    <MenuItem text="%menu.about" onAction="#showAbout"/>
                </Menu>
            </MenuBar>
        </VBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="20">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            <ImageView fitWidth="96" fitHeight="96" preserveRatio="true">
                <image>
                    <Image url="@logo.png"/>
                </image>
            </ImageView>
            <Label text="%app.title" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
            <Label text="%about.description" wrapText="true" style="-fx-font-size: 14px;"/>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 5 10 5 10; -fx-background-color: -color-bg-subtle;">
            <Label fx:id="statusLabel" text="%status.ready"/>
        </HBox>
    </bottom>

</BorderPane>
